{
  "StartGame": {
    "recognition": "DirectHit",
    "action": "StartApp",
    "package": "com.bilibili.star.bili",
    "next": ["HomeMarker", "LoginTapToStart", "LoginNext", "CommonClose"],
    "on_error": ["CommonRecover"]
  },
  "HomeMarker": {
    "recognition": "TemplateMatch",
    "template": "home_marker.png",
    "threshold": 0.88,
    "action": "DoNothing"
  },
  "LoginTapToStart": {
    "recognition": "TemplateMatch",
    "template": "login_tap_to_start.png",
    "threshold": 0.90,
    "action": "Click",
    "next": ["HomeMarker", "LoginNext", "CommonClose", "LoginTapToStart"],
    "on_error": ["CommonRecover"]
  },
  "LoginNext": {
    "recognition": "TemplateMatch",
    "template": "login_next.png",
    "threshold": 0.90,
    "action": "Click",
    "next": ["HomeMarker", "LoginNext", "CommonClose"],
    "on_error": ["CommonRecover"]
  },
  "CommonClose": {
    "recognition": "TemplateMatch",
    "template": "common_close.png",
    "threshold": 0.90,
    "action": "Click",
    "next": ["HomeMarker", "LoginNext", "CommonClose"],
    "on_error": ["CommonRecover"]
  },
  "CommonRecover": {
    "recognition": "DirectHit",
    "action": "Custom",
    "custom_action": "CommonRecover",
    "custom_action_param": {
      "home_node": "HomeMarker",
      "escape_interval_ms": 1500,
      "escape_timeout_ms": 30000,
      "restart_limit": 2,
      "package": "com.bilibili.star.bili"
    },
    "next": ["HomeMarker"]
  }
}
