{
  "$schema": "https://raw.githubusercontent.com/MaaXYZ/MaaFramework/main/tools/interface.schema.json",
  "interface_version": 2,
  "name": "MaaBanGDream",
  "label": "BanG Dream! 自动化（MaaFramework）",
  "version": "0.2.0",
  "description": "BanG Dream! 的 MaaFramework 自动化项目；当前提供最小页面闭环和当前歌曲单轮自动演出。",
  "license": "GPL-3.0-only",
  "controller": [
    {
      "name": "Android",
      "label": "Android 模拟器（1280×720）",
      "type": "Adb",
      "display_short_side": 720
    }
  ],
  "resource": [
    {
      "name": "Bilibili",
      "label": "哔哩哔哩服",
      "path": ["./resource"],
      "controller": ["Android"]
    }
  ],
  "agent": {
    "child_exec": "./.venv/Scripts/python.exe",
    "child_args": ["./agent/server.py"]
  },
  "task": [
    {
      "name": "MinimalNavigation",
      "label": "页面流连通性测试",
      "entry": "MinimalNavigation"
    },
    {
      "name": "AutoLive",
      "label": "单轮自动演出",
      "description": "对游戏当前选中的歌曲执行一次自动演出，完成结算后返回主页。",
      "entry": "AutoLive"
    }
  ]
}
